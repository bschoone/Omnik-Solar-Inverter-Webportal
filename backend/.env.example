# HTTP API
PORT=3000
HOST=0.0.0.0

# SQLite (use /data/... in Docker; local dev: paths under backend/)
SOLAR_DB_PATH=./data/samples.sqlite3

# Inverter / collector (HTTP + optional TCP push)
# Use your stick’s LAN URL (example below is TEST-NET-1 — not a routable host).
INVERTER_BASE=http://192.0.2.10
INVERTER_TCP_ENABLE=1
INVERTER_TCP_LISTEN_HOST=0.0.0.0
INVERTER_TCP_LISTEN_PORT=8899
INVERTER_STICK_HOST=
INVERTER_STICK_TCP_PORT=8899
INVERTER_TCP_SERIAL=0
POLL_INTERVAL_SEC=15
INVERTER_STALE_SEC=120
INVERTER_HTTP_USER=
INVERTER_HTTP_PASSWORD=
INVERTER_HTTP_TIMEOUT_SEC=15
INVERTER_FETCH=auto
INVERTER_HTTP_COMPARE_INTERVAL_SEC=0
INVERTER_HTTP_COMPARE_DELTA_W=150
INVERTER_TEST_PULL_INTERVAL_SEC=0

# Test TCP push ingestion (backend running, INVERTER_TCP_ENABLE=1):
#   npm run tcp:send-test -- 127.0.0.1 8899
#   npm run tcp:send-test -- <stick-host> 8899 --file ./capture.hex

# Store every TCP push frame as a BLOB (parsed OK → parse_error null, plus samples row).
RAW_EVENT_LOG_ENABLE=0
RAW_EVENT_MAX_ROWS=5000

# Backups
SQLITE_BACKUP_INTERVAL_SEC=86400
SQLITE_BACKUP_DIR=./data/backups
SQLITE_BACKUP_KEEP=14
# Long random values in your real .env if you use backup / admin HTTP routes.
BACKUP_API_TOKEN=
ADMIN_API_TOKEN=
