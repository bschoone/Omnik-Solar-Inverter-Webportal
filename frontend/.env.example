# Optional: API origin when the UI is not same-origin (e.g. static hosting).
# Leave unset during `npm run dev` so `/api` uses the Vite proxy.
# VITE_API_BASE=http://127.0.0.1:3000

# Optional: override Scalar/OpenAPI docs URL (same host as API in most setups).
# VITE_DOCS_URL=http://127.0.0.1:3000/documentation
